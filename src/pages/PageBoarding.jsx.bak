import { useState } from "react";
import { uid } from "../data/constants";
import { Ic, Avt, Badge, Inp, Sel, Lbl, Btn, Modal, Confirm, Card, PageHeader, Tabs, Table, Empty, SearchInp } from "../components/UI";

function AddEmpForm({ form, setForm, onSave, onClose }) {
  return (
    <div className="space-y-4">
      <div><Lbl>Full Name</Lbl><Inp value={form.name} onChange={e=>setForm(p=>({...p,name:e.target.value}))} placeholder="e.g. Raj Kumar"/></div>
      <div><Lbl>Address</Lbl><Inp value={form.address} onChange={e=>setForm(p=>({...p,address:e.target.value}))} placeholder="e.g. Sector 62, Noida"/></div>
      <div><Lbl>Geo Coordinates</Lbl><Inp value={form.coords} onChange={e=>setForm(p=>({...p,coords:e.target.value}))} placeholder="e.g. 28.6139°N 77.2090°E"/></div>
      <div><Lbl>Shift Time</Lbl>
        <Sel value={form.shift} onChange={e=>setForm(p=>({...p,shift:e.target.value}))}>
          <option>08:30 AM</option><option>09:00 AM</option><option>10:00 AM</option>
        </Sel>
      </div>
      <div className="flex gap-3 pt-2">
        <Btn v="secondary" className="flex-1" onClick={onClose}>Cancel</Btn>
        <Btn className="flex-1" onClick={onSave}><Ic n="plus" c="w-4 h-4"/>Add Employee</Btn>
      </div>
    </div>
  );
}

function AssignForm({ routes, cars, routeId, setRouteId, onSave, onClose }) {
  return (
    <div className="space-y-4">
      <div>
        <Lbl>Select Route</Lbl>
        <Sel value={routeId} onChange={e=>setRouteId(e.target.value)}>
          <option value="">— Choose route —</option>
          {routes.map(r => {
            const cap = (cars.find(c=>c.id===r.carId)||{}).capacity||0;
            return <option key={r.id} value={r.id} disabled={r.employeeIds.length>=cap}>{r.name} ({r.employeeIds.length}/{cap}) · {r.shift}</option>;
          })}
        </Sel>
      </div>
      <div className="flex gap-3 pt-2">
        <Btn v="secondary" className="flex-1" onClick={onClose}>Cancel</Btn>
        <Btn className="flex-1" onClick={onSave} disabled={!routeId}>Assign</Btn>
      </div>
    </div>
  );
}

export default function PageBoarding({ emp, setEmp, routes, cars, toast }) {
  const [filter, setFilter]     = useState("all");
  const [search, setSearch]     = useState("");
  const [assignTarget, setAT]   = useState(null);
  const [assignRoute,  setAR]   = useState("");
  const [addOpen, setAddOpen]   = useState(false);
  const [newE, setNewE]         = useState({ name:"", address:"", coords:"", shift:"09:00 AM" });
  const [confirmDel, setConfirmDel] = useState(null);

  const list = emp
    .filter(e => filter === "all" || e.status === filter)
    .filter(e => !search || e.name.toLowerCase().includes(search.toLowerCase()) || e.id.toLowerCase().includes(search.toLowerCase()));

  const act = (id, status) => {
    setEmp(p => p.map(e => e.id === id ? {...e, status} : e));
    toast(status === "approved" ? "Request approved ✓" : "Rejected", status === "approved" ? "success" : "error");
  };
  const doAssign = () => {
    if (!assignRoute) return;
    setEmp(p => p.map(e => e.id === assignTarget.id ? {...e, routeId: assignRoute, status:"approved"} : e));
    toast("Employee assigned to route ✓","success"); setAT(null);
  };
  const doAdd = () => {
    if (!newE.name.trim()) return;
    setEmp(p => [...p, {...newE, id:`EMP${uid()}`, status:"pending", routeId:null}]);
    toast("Employee added ✓","success"); setAddOpen(false);
    setNewE({ name:"", address:"", coords:"", shift:"09:00 AM" });
  };
  const doDel = id => { setEmp(p => p.filter(e => e.id !== id)); toast("Removed","info"); setConfirmDel(null); };

  const tabs = [
    { id:"all",      label:"All",      count: emp.length },
    { id:"pending",  label:"Pending",  count: emp.filter(e=>e.status==="pending").length },
    { id:"approved", label:"Approved", count: emp.filter(e=>e.status==="approved").length },
    { id:"rejected", label:"Rejected", count: emp.filter(e=>e.status==="rejected").length },
  ];

  return (
    <div className="space-y-5 max-w-[1400px]">
      <PageHeader title="Boarding Requests" sub="Review and manage employee transport requests">
        <Btn onClick={() => setAddOpen(true)}><Ic n="plus" c="w-4 h-4"/>Add Employee</Btn>
      </PageHeader>

      <div className="flex flex-wrap items-center gap-3">
        <Tabs tabs={tabs} active={filter} onChange={setFilter} />
        <div className="flex-1"/>
        <SearchInp value={search} onChange={e=>setSearch(e.target.value)} placeholder="Search name or ID…"/>
      </div>

      <Card className="overflow-hidden fu">
        <Table headers={["Employee","ID","Location","Shift","Status","Actions"]} minW="700px">
          {list.length === 0
            ? <tr><td colSpan={6}><Empty icon="users" text="No employees found" /></td></tr>
            : list.map(e => (
              <tr key={e.id} className="hover:bg-indigo-50/30 transition-colors group">
                <td className="px-5 py-3.5">
                  <div className="flex items-center gap-3">
                    <Avt name={e.name}/>
                    <div>
                      <p className="text-sm font-bold text-slate-800">{e.name}</p>
                      <p className="text-[11px] text-slate-400 font-mono">{e.id}</p>
                    </div>
                  </div>
                </td>
                <td className="px-5 py-3.5 font-mono text-xs text-slate-400 hidden lg:table-cell">{e.id}</td>
                <td className="px-5 py-3.5 hidden md:table-cell">
                  <div className="flex items-center gap-1 text-xs text-sky-600 font-semibold">
                    <Ic n="pin" c="w-3.5 h-3.5 flex-shrink-0"/>{e.coords || e.address}
                  </div>
                </td>
                <td className="px-5 py-3.5">
                  <span className="text-xs font-bold px-2.5 py-1 rounded-full"
                    style={{ background: "#f1f5f9", color: "#475569" }}>{e.shift}</span>
                </td>
                <td className="px-5 py-3.5"><Badge s={e.status}/></td>
                <td className="px-5 py-3.5">
                  <div className="flex items-center gap-1">
                    {e.status !== "approved" && (
                      <button onClick={()=>act(e.id,"approved")} title="Approve"
                        className="w-7 h-7 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                        style={{ background:"#dcfce7", color:"#16a34a" }}>
                        <Ic n="check" c="w-3.5 h-3.5"/>
                      </button>
                    )}
                    {e.status !== "rejected" && (
                      <button onClick={()=>act(e.id,"rejected")} title="Reject"
                        className="w-7 h-7 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                        style={{ background:"#fee2e2", color:"#dc2626" }}>
                        <Ic n="x" c="w-3.5 h-3.5"/>
                      </button>
                    )}
                    <button onClick={()=>{setAT(e);setAR(e.routeId||"");}} title="Assign Route"
                      className="w-7 h-7 rounded-lg flex items-center justify-center transition-all hover:scale-110"
                      style={{ background:"#ede9fe", color:"#7c3aed" }}>
                      <Ic n="swap" c="w-3.5 h-3.5"/>
                    </button>
                    <button onClick={()=>setConfirmDel(e.id)} title="Delete"
                      className="w-7 h-7 rounded-lg flex items-center justify-center transition-all hover:scale-110 opacity-0 group-hover:opacity-100"
                      style={{ background:"#f8fafc", color:"#94a3b8" }}>
                      <Ic n="trash" c="w-3.5 h-3.5"/>
                    </button>
                  </div>
                </td>
              </tr>
            ))
          }
        </Table>
      </Card>

      <Modal open={!!assignTarget} onClose={()=>setAT(null)} title={`Assign Route — ${assignTarget?.name}`}>
        <AssignForm routes={routes} cars={cars} routeId={assignRoute} setRouteId={setAR} onSave={doAssign} onClose={()=>setAT(null)}/>
      </Modal>
      <Modal open={addOpen} onClose={()=>setAddOpen(false)} title="Add New Employee">
        <AddEmpForm form={newE} setForm={setNewE} onSave={doAdd} onClose={()=>setAddOpen(false)}/>
      </Modal>
      <Confirm open={!!confirmDel} msg="Remove this employee permanently?" onYes={()=>doDel(confirmDel)} onNo={()=>setConfirmDel(null)}/>
    </div>
  );
}
